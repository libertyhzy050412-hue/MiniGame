{
  "name": "war-and-peace-v1",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:web": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "build:web": "npm run typecheck && vite build",
    "build": "npm run build:web && electron-builder",
    "preview": "vite preview --host 127.0.0.1"
  },
  "build": {
    "appId": "com.minigame.warandpeace",
    "productName": "锈甲长歌",
    "directories": {
      "output": "release"
    },
    "files": [
      "renderer/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "锈甲长歌"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "phaser": "^4.0.0"
  }
}
